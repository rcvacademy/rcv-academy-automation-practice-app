<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Automation Practice Website' %> | Software Testing Mentor & RCV Academy</title>

  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
        integrity="sha512-1ycn6IcaQQ40/MKBW2W4Rhis/DbILU74C1vSrLJxCq57o941Ym01SwNsOMqvEBFlcgUa6xLiPY/NS5R+E6ztJQ=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- jQuery (for jQuery UI pages) -->
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"
          integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
          crossorigin="anonymous"></script>
  <!-- jQuery UI -->
  <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"
          integrity="sha256-lSjKY0/srUM9BE3dPm+c4fBo1dky2v27Gdjm2uoZaL0="
          crossorigin="anonymous"></script>
  <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/smoothness/jquery-ui.css"
        integrity="sha256-cPSccRMnDkmGRU/lPA5LPdeBlVEbByYtbSJULwlp7lA="
        crossorigin="anonymous" />
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/files/stm-logo-720.png" />
  <!-- App stylesheet -->
  <link rel="stylesheet" href="/css/style.css" />
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>

  <% if (typeof gaId !== 'undefined' && gaId) { %>
  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', '<%= gaId %>');
  </script>
  <% } %>
</head>
<body id="app-body" data-page="<%= activePage %>">

  <!-- ===== Top bar (full width) ===== -->
  <header class="topbar" role="banner">
    <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="Open menu">
      <i class="fas fa-bars" aria-hidden="true"></i>
    </button>

    <!-- Header logo + app title -->
    <a href="/" class="header-brand" title="Home">
      <img src="/files/stm-logo-720.png" alt="Software Testing Mentor" class="header-logo-img" />
      <span class="header-brand-text">STM & RCV Academy<br/><small>Automation Practice Website</small></span>
    </a>

    <!-- Header navigation links -->
    <nav class="header-nav" aria-label="Header navigation">
      <a href="/" class="header-nav-link" id="header-home" data-testid="header-home">
        <i class="fas fa-home" aria-hidden="true"></i> Home
      </a>
      <a href="https://training.rcvacademy.com/" target="_blank" rel="noopener noreferrer"
         class="header-nav-link" id="header-rcv-portal" data-testid="header-rcv-portal">
        <i class="fas fa-graduation-cap" aria-hidden="true"></i> RCV Academy eLearning Portal
      </a>
    </nav>

    <!-- Header social icons -->
    <div class="header-social" aria-label="Social media links">
      <a href="https://www.youtube.com/@softwaretestingmentor" target="_blank" rel="noopener noreferrer"
         class="header-social-icon" id="header-yt-stm" data-testid="header-yt-stm" aria-label="YouTube - Software Testing Mentor" title="YouTube - STM">
        <i class="fab fa-youtube" aria-hidden="true"></i>
      </a>
      <a href="https://www.youtube.com/@rcvacademy" target="_blank" rel="noopener noreferrer"
         class="header-social-icon" id="header-yt-rcv" data-testid="header-yt-rcv" aria-label="YouTube - RCV Academy" title="YouTube - RCV Academy">
        <i class="fab fa-youtube" aria-hidden="true"></i>
      </a>
      <a href="https://www.linkedin.com/company/rcvacademy" target="_blank" rel="noopener noreferrer"
         class="header-social-icon" id="header-linkedin" data-testid="header-linkedin" aria-label="LinkedIn" title="LinkedIn">
        <i class="fab fa-linkedin-in" aria-hidden="true"></i>
      </a>
      <a href="https://www.instagram.com/softwaretestingmentor" target="_blank" rel="noopener noreferrer"
         class="header-social-icon" id="header-instagram" data-testid="header-instagram" aria-label="Instagram" title="Instagram">
        <i class="fab fa-instagram" aria-hidden="true"></i>
      </a>
    </div>
  </header>

  <% if (typeof sponsors !== 'undefined' && sponsors.diamond && sponsors.diamond.length > 0) { %>
  <!-- Diamond Sponsor – leaderboard banner (header) -->
  <div class="sponsor-banner sponsor-banner--diamond" id="sponsor-banner-diamond" data-testid="sponsor-banner-diamond">
    <span class="sponsor-banner__label"><i class="fas fa-gem"></i> Diamond Sponsor</span>
    <div class="sponsor-banner__items">
      <% sponsors.diamond.forEach(function(s) { %>
      <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer sponsored"
         class="sponsor-banner__link sponsor-banner__link--diamond" data-testid="sponsor-link-diamond">
        <img src="<%= s.image %>" alt="<%= s.alt %>" class="sponsor-banner__img sponsor-banner__img--diamond" loading="lazy" />
      </a>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- ===== Sidebar + Main content row ===== -->
  <div class="app-row">

  <!-- Sidebar overlay (mobile) -->
  <div id="sidebar-overlay" class="sidebar-overlay"></div>

  <!-- ===== Sidebar / Left-hand menu ===== -->
  <nav id="sidebar" class="sidebar" aria-label="Main navigation">
    <div class="sidebar-header">
      <button id="sidebar-collapse-btn" class="sidebar-toggle" aria-label="Toggle sidebar" title="Collapse sidebar">
        <i class="fas fa-bars nav-icon" aria-hidden="true"></i> <span class="sidebar-toggle-text">Collapse Menu</span> <i class="fas fa-chevron-left sidebar-collapse-arrow" aria-hidden="true"></i>
      </button>
    </div>

    <ul class="nav-list" role="menubar">
      <% menuItems.forEach(function(item) { %>
        <li class="nav-item" role="none">
          <a href="<%= item.href %>"
             class="nav-link <%= activePage === item.href.replace('/', '') || (item.href === '/' && activePage === 'index') ? 'active' : '' %>"
             role="menuitem"
             id="nav-<%= item.href.replace(/\//g, '') || 'home' %>"
             title="<%= item.label %>">
            <i class="fas <%= item.icon %> nav-icon" aria-hidden="true"></i>
            <span class="nav-label"><%= item.label %></span>
          </a>
        </li>
      <% }); %>
    </ul>
  </nav><!-- /#sidebar -->

  <!-- ===== Main content area ===== -->
  <div id="main-wrapper" class="main-wrapper">

    <!-- Page content -->
    <main id="page-content" class="page-content" role="main">
      <%- body %>
    </main>

  </div><!-- /#main-wrapper -->

  </div><!-- /.app-row -->

  <% if (typeof sponsors !== 'undefined' && (sponsors.platinum.length || sponsors.gold.length || sponsors.silver.length)) { %>
  <!-- Footer sponsor tiers -->
  <div class="sponsor-tiers" id="sponsor-tiers-footer" data-testid="sponsor-tiers-footer">

    <% if (sponsors.platinum && sponsors.platinum.length > 0) { %>
    <!-- Platinum Sponsors – small banners -->
    <div class="sponsor-tier sponsor-tier--platinum" id="sponsor-tier-platinum" data-testid="sponsor-tier-platinum">
      <h4 class="sponsor-tier__heading"><i class="fas fa-award"></i> Platinum Sponsors</h4>
      <div class="sponsor-tier__items">
        <% sponsors.platinum.forEach(function(s) { %>
        <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer sponsored"
           class="sponsor-tier__link sponsor-tier__link--platinum" data-testid="sponsor-link-platinum">
          <img src="<%= s.image %>" alt="<%= s.alt %>" class="sponsor-tier__img sponsor-tier__img--platinum" loading="lazy" />
          <span class="sponsor-tier__name"><%= s.name %></span>
        </a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (sponsors.gold && sponsors.gold.length > 0) { %>
    <!-- Gold Sponsors – medium logo only -->
    <div class="sponsor-tier sponsor-tier--gold" id="sponsor-tier-gold" data-testid="sponsor-tier-gold">
      <h4 class="sponsor-tier__heading"><i class="fas fa-medal"></i> Gold Sponsors</h4>
      <div class="sponsor-tier__items">
        <% sponsors.gold.forEach(function(s) { %>
        <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer sponsored"
           class="sponsor-tier__link sponsor-tier__link--gold" data-testid="sponsor-link-gold"
           title="<%= s.name %>">
          <img src="<%= s.image %>" alt="<%= s.alt %>" class="sponsor-tier__img sponsor-tier__img--gold" loading="lazy" />
        </a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <p class="sponsor-enquiry" data-testid="sponsor-enquiry-footer">
      <i class="fas fa-envelope" aria-hidden="true"></i> Interested in sponsoring?
      Contact <a href="mailto:admin@rcvacademy.com">admin@rcvacademy.com</a> |
      <a href="mailto:admin@softwaretestingmentor.com">admin@softwaretestingmentor.com</a>
    </p>

  </div>
  <% } %>

  <footer class="app-footer" role="contentinfo">
      <div class="footer-links">
        <a href="/" class="footer-link" id="footer-home" data-testid="footer-home">
          <i class="fas fa-home" aria-hidden="true"></i> Home
        </a>
        <a href="/terms" class="footer-link" id="footer-terms" data-testid="footer-terms">
          <i class="fas fa-file-contract" aria-hidden="true"></i> Terms &amp; Conditions
        </a>
        <a href="/privacy-policy" class="footer-link" id="footer-privacy" data-testid="footer-privacy">
          <i class="fas fa-shield-alt" aria-hidden="true"></i> Privacy Policy
        </a>
        <a href="https://training.rcvacademy.com/" target="_blank" rel="noopener noreferrer"
           class="footer-link" id="footer-rcv-portal" data-testid="footer-rcv-portal">
          <i class="fas fa-graduation-cap" aria-hidden="true"></i> RCV Academy eLearning Portal
        </a>
        <a href="https://training.rcvacademy.com/courses" target="_blank" rel="noopener noreferrer"
           class="footer-link" id="footer-courses" data-testid="footer-courses">
          <i class="fas fa-book" aria-hidden="true"></i> Our Courses
        </a>
      </div>
      <div class="footer-social">
        <a href="https://www.youtube.com/@softwaretestingmentor" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-yt-stm" data-testid="social-yt-stm" aria-label="YouTube - Software Testing Mentor">
          <i class="fab fa-youtube" aria-hidden="true"></i>
        </a>
        <a href="https://www.youtube.com/@rcvacademy" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-yt-rcv" data-testid="social-yt-rcv" aria-label="YouTube - RCV Academy">
          <i class="fab fa-youtube" aria-hidden="true"></i>
        </a>
        <a href="https://www.linkedin.com/company/rcvacademy" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-linkedin" data-testid="social-linkedin" aria-label="LinkedIn">
          <i class="fab fa-linkedin-in" aria-hidden="true"></i>
        </a>
        <a href="https://www.instagram.com/softwaretestingmentor" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-instagram" data-testid="social-instagram" aria-label="Instagram">
          <i class="fab fa-instagram" aria-hidden="true"></i>
        </a>
        <a href="https://www.facebook.com/rcvacademy47" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-fb-rcv" data-testid="social-fb-rcv" aria-label="Facebook - RCV Academy">
          <i class="fab fa-facebook-f" aria-hidden="true"></i>
        </a>
        <a href="https://www.facebook.com/softwaretestingmentor" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-fb-stm" data-testid="social-fb-stm" aria-label="Facebook - Software Testing Mentor">
          <i class="fab fa-facebook-f" aria-hidden="true"></i>
        </a>
        <a href="https://x.com/rcvacademy" target="_blank" rel="noopener noreferrer"
           class="footer-social-icon" id="social-x" data-testid="social-x" aria-label="X (Twitter)">
          <i class="fab fa-twitter" aria-hidden="true"></i>
        </a>
      </div>
      <p class="footer-copy">Software Testing Mentor &amp; RCV Academy Automation Practice Website &mdash; &copy; 2026 RCV Academy. All rights reserved.</p>
  </footer>

  <!-- ===== Scripts ===== -->
  <!-- Main app JS -->
  <script src="/js/main.js"></script>
  <script>
  (function() {
    var token = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
    if (!token) return;
    document.querySelectorAll('form').forEach(function(f) {
      if (f.method === 'post' && !f.querySelector('input[name="_csrf"]')) {
        var i = document.createElement('input');
        i.type = 'hidden'; i.name = '_csrf'; i.value = token;
        f.appendChild(i);
      }
    });
  })();
  </script>
  <%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>
