<%# RCV Academy eStore – Order Detail Page %>
<%- include('layout') %>
<div class="store-body" role="main" id="order-detail-page" data-testid="order-detail-page">

  <!-- Breadcrumb -->
  <nav class="store-breadcrumb" aria-label="Breadcrumb navigation" id="order-detail-breadcrumb" data-testid="order-detail-breadcrumb">
    <a href="/store" id="bc-home" data-testid="bc-home">Home</a>
    <span class="sep" aria-hidden="true">›</span>
    <a href="/store/orders" id="bc-orders" data-testid="bc-orders">My Orders</a>
    <span class="sep" aria-hidden="true">›</span>
    <span aria-current="page">Order #<%= order.id %></span>
  </nav>

  <!-- Header row -->
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;"
       id="order-detail-header" data-testid="order-detail-header">
    <h1 class="store-section-heading" style="margin-bottom:0;" id="order-detail-heading" data-testid="order-detail-heading">
      <i class="fas fa-box" aria-hidden="true" style="color:var(--store-primary);"></i>
      Order #<%= order.id %>
    </h1>
    <div style="display:flex;align-items:center;gap:10px;">
      <span class="order-status-badge status-<%= order.status %>"
            id="order-detail-status" data-testid="order-detail-status">
        <%= order.status %>
      </span>
      <% if (order.status === 'processing') { %>
        <form action="/store/orders/<%= order.id %>/cancel" method="POST" style="display:inline;">
          <button type="submit" class="store-btn store-btn-danger"
                  id="cancel-order-btn" data-testid="cancel-order-btn"
                  aria-label="Cancel order <%= order.id %>"
                  onclick="return confirm('Cancel this order?')">
            <i class="fas fa-times" aria-hidden="true"></i> Cancel Order
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="order-detail-grid" id="order-detail-grid" data-testid="order-detail-grid">

    <!-- Left column: items + tracking -->
    <div id="order-detail-left" data-testid="order-detail-left">

      <!-- Order items -->
      <div style="background:#fff;border-radius:10px;box-shadow:var(--store-shadow);padding:22px;margin-bottom:20px;"
           id="order-items-card" data-testid="order-items-card" role="region" aria-label="Order items">
        <h2 style="font-size:16px;font-weight:700;margin-bottom:16px;" id="order-items-heading">Items Ordered</h2>
        <table class="store-table" id="order-items-table" data-testid="order-items-table" aria-label="Items in this order">
          <thead>
            <tr>
              <th scope="col">Product</th>
              <th scope="col">Unit Price</th>
              <th scope="col">Qty</th>
              <th scope="col">Total</th>
            </tr>
          </thead>
          <tbody>
            <% order.items.forEach(function(item, i) { %>
              <tr id="od-item-row-<%= i+1 %>" data-testid="od-item-row-<%= i+1 %>">
                <td>
                  <div style="display:flex;align-items:center;gap:12px;">
                    <img src="<%= item.image %>" alt="<%= item.name %>"
                         style="width:56px;height:56px;object-fit:contain;background:#f8f9fb;border-radius:6px;padding:4px;border:1px solid var(--store-border);flex-shrink:0;"
                         id="od-img-<%= i+1 %>" data-testid="od-img-<%= i+1 %>" />
                    <div>
                      <div style="font-weight:600;font-size:14px;" id="od-name-<%= i+1 %>" data-testid="od-name-<%= i+1 %>"><%= item.name %></div>
                      <div style="font-size:12px;color:#64748b;" id="od-cat-<%= i+1 %>" data-testid="od-cat-<%= i+1 %>"><%= item.category %></div>
                    </div>
                  </div>
                </td>
                <td id="od-unit-price-<%= i+1 %>" data-testid="od-unit-price-<%= i+1 %>">$<%= item.price.toFixed(2) %></td>
                <td id="od-qty-<%= i+1 %>" data-testid="od-qty-<%= i+1 %>"><%= item.qty %></td>
                <td style="font-weight:700;" id="od-subtotal-<%= i+1 %>" data-testid="od-subtotal-<%= i+1 %>">$<%= (item.price * item.qty).toFixed(2) %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Tracking timeline -->
      <div style="background:#fff;border-radius:10px;box-shadow:var(--store-shadow);padding:22px;"
           id="order-tracking-card" data-testid="order-tracking-card" role="region" aria-label="Order tracking">
        <h2 style="font-size:16px;font-weight:700;margin-bottom:16px;" id="order-tracking-heading">
          <i class="fas fa-truck" aria-hidden="true" style="color:var(--store-primary);"></i> Order Tracking
        </h2>
        <ul class="order-timeline" id="order-timeline" data-testid="order-timeline"
            aria-label="Order tracking timeline">
          <li class="done" id="timeline-ordered" data-testid="timeline-ordered">
            <div class="timeline-title">Order Placed</div>
            <div class="timeline-date"><%= order.date %></div>
          </li>
          <li class="<%= ['shipped','delivered'].includes(order.status) ? 'done' : (order.status === 'processing' ? 'active' : '') %>"
              id="timeline-processing" data-testid="timeline-processing">
            <div class="timeline-title">Processing</div>
            <div class="timeline-date">Preparing your order</div>
          </li>
          <li class="<%= order.status === 'shipped' ? 'active' : (order.status === 'delivered' ? 'done' : '') %>"
              id="timeline-shipped" data-testid="timeline-shipped">
            <div class="timeline-title">Shipped</div>
            <div class="timeline-date"><%= order.status === 'delivered' || order.status === 'shipped' ? 'On the way' : 'Pending' %></div>
          </li>
          <li class="<%= order.status === 'delivered' ? 'done active' : '' %>"
              id="timeline-delivered" data-testid="timeline-delivered">
            <div class="timeline-title">Delivered</div>
            <div class="timeline-date">Est. <%= order.estDelivery %></div>
          </li>
        </ul>
      </div>

    </div><!-- /.order-detail-left -->

    <!-- Right column: summary panel -->
    <aside id="order-detail-right" data-testid="order-detail-right"
           role="complementary" aria-label="Order summary">

      <!-- Order summary -->
      <div class="store-summary-panel" style="margin-bottom:16px;" id="od-summary-panel" data-testid="od-summary-panel">
        <h3 id="od-summary-heading">Order Summary</h3>
        <div class="summary-row" id="od-subtotal-row" data-testid="od-subtotal-row">
          <span>Subtotal</span>
          <span id="od-subtotal-val" data-testid="od-subtotal-val">$<%= order.subtotal.toFixed(2) %></span>
        </div>
        <div class="summary-row" id="od-shipping-row" data-testid="od-shipping-row">
          <span>Shipping</span>
          <span id="od-shipping-val" data-testid="od-shipping-val">
            <% if (order.shipping === 0) { %><span style="color:#22c55e;">FREE</span><% } else { %>$<%= order.shipping.toFixed(2) %><% } %>
          </span>
        </div>
        <div class="summary-row" id="od-tax-row" data-testid="od-tax-row">
          <span>Tax</span>
          <span id="od-tax-val" data-testid="od-tax-val">$<%= order.tax.toFixed(2) %></span>
        </div>
        <% if (order.discount > 0) { %>
          <div class="summary-row discount" id="od-discount-row" data-testid="od-discount-row">
            <span>Discount</span>
            <span id="od-discount-val" data-testid="od-discount-val">-$<%= order.discount.toFixed(2) %></span>
          </div>
        <% } %>
        <div class="summary-row total" id="od-total-row" data-testid="od-total-row">
          <span>Total</span>
          <span id="od-total-val" data-testid="od-total-val">$<%= order.total.toFixed(2) %></span>
        </div>
      </div>

      <!-- Shipping info -->
      <div style="background:#fff;border-radius:10px;box-shadow:var(--store-shadow);padding:18px;margin-bottom:16px;font-size:13px;"
           id="od-ship-info" data-testid="od-ship-info" role="region" aria-label="Shipping information">
        <div style="font-weight:700;margin-bottom:8px;font-size:14px;">
          <i class="fas fa-map-marker-alt" aria-hidden="true" style="color:var(--store-primary);"></i> Shipping Address
        </div>
        <div id="od-ship-name" data-testid="od-ship-name"><%= order.shipName %></div>
        <div id="od-ship-addr" data-testid="od-ship-addr"><%= order.shipAddress %></div>
        <div id="od-ship-city-line" data-testid="od-ship-city-line"><%= order.shipCity %></div>
        <div style="margin-top:8px;color:#64748b;" id="od-ship-method" data-testid="od-ship-method">
          <i class="fas fa-truck" aria-hidden="true"></i> <%= order.shippingMethod %>
        </div>
      </div>

      <!-- Payment info -->
      <div style="background:#fff;border-radius:10px;box-shadow:var(--store-shadow);padding:18px;font-size:13px;"
           id="od-pay-info" data-testid="od-pay-info" role="region" aria-label="Payment information">
        <div style="font-weight:700;margin-bottom:8px;font-size:14px;">
          <i class="fas fa-credit-card" aria-hidden="true" style="color:var(--store-primary);"></i> Payment
        </div>
        <div id="od-pay-method" data-testid="od-pay-method"><%= order.paymentMethod %></div>
        <div style="color:#22c55e;font-weight:600;margin-top:4px;" id="od-pay-status" data-testid="od-pay-status">
          <i class="fas fa-check-circle" aria-hidden="true"></i> Payment Confirmed
        </div>
      </div>

    </aside>

  </div><!-- /.order-detail-grid -->

</div><!-- /.store-body -->
