<%# jQuery UI Menu Page %>
<div class="page-header">
  <h2><i class="fas fa-bars"></i> jQuery UI Menu</h2>
  <p>A fully functional jQuery UI hierarchical menu. Practice locating menu items, sub-menus, and hover states.</p>
</div>

<div class="d-flex gap-3 flex-wrap">

  <!-- Horizontal jQuery UI menu -->
  <div class="card" style="flex:1;min-width:300px;">
    <div class="card-title">jQuery UI Horizontal Menu</div>
    <nav id="jquery-menu-nav" aria-label="jQuery UI demo menu">
      <ul id="jquery-menu" data-testid="jquery-menu">
        <li id="menu-file"><a href="#" id="menu-file-link" data-testid="menu-file">File</a>
          <ul>
            <li id="menu-new"><a href="#" data-testid="menu-new">New</a>
              <ul>
                <li><a href="#" id="menu-new-doc"    data-testid="menu-new-doc">Document</a></li>
                <li><a href="#" id="menu-new-folder" data-testid="menu-new-folder">Folder</a></li>
              </ul>
            </li>
            <li id="menu-open">  <a href="#" data-testid="menu-open">Open</a></li>
            <li id="menu-save">  <a href="#" data-testid="menu-save">Save</a></li>
            <li class="ui-menu-divider"></li>
            <li id="menu-exit">  <a href="#" data-testid="menu-exit">Exit</a></li>
          </ul>
        </li>
        <li id="menu-edit"><a href="#" id="menu-edit-link" data-testid="menu-edit">Edit</a>
          <ul>
            <li id="menu-cut">   <a href="#" data-testid="menu-cut">Cut</a></li>
            <li id="menu-copy">  <a href="#" data-testid="menu-copy">Copy</a></li>
            <li id="menu-paste"> <a href="#" data-testid="menu-paste">Paste</a></li>
            <li class="ui-menu-divider"></li>
            <li id="menu-selall"><a href="#" data-testid="menu-selall">Select All</a></li>
          </ul>
        </li>
        <li id="menu-view"><a href="#" id="menu-view-link" data-testid="menu-view">View</a>
          <ul>
            <li id="menu-zoom">  <a href="#" data-testid="menu-zoom">Zoom</a>
              <ul>
                <li><a href="#" data-testid="menu-zoom-in">Zoom In</a></li>
                <li><a href="#" data-testid="menu-zoom-out">Zoom Out</a></li>
                <li><a href="#" data-testid="menu-zoom-reset">Reset Zoom</a></li>
              </ul>
            </li>
            <li id="menu-fullscreen"><a href="#" data-testid="menu-fullscreen">Full Screen</a></li>
          </ul>
        </li>
        <li id="menu-help"><a href="#" id="menu-help-link" data-testid="menu-help">Help</a>
          <ul>
            <li><a href="#" data-testid="menu-docs">Documentation</a></li>
            <li><a href="#" data-testid="menu-about">About</a></li>
          </ul>
        </li>
      </ul>
    </nav>
    <p id="menu-action-result" class="mt-3 text-muted" data-testid="menu-action-result" style="font-size:13px;"></p>
  </div>

  <!-- Simple custom styled navigation menu -->
  <div class="card" style="flex:1;min-width:260px;">
    <div class="card-title">Custom CSS Navigation Menu</div>
    <nav id="custom-nav-menu" aria-label="Custom navigation menu" data-testid="custom-nav-menu">
      <ul style="list-style:none;display:flex;flex-direction:column;gap:2px;">
        <% ['Dashboard','Reports','Analytics','Settings','Profile','Logout'].forEach(function(item){ %>
          <li>
            <a href="#" id="nav-item-<%= item.toLowerCase() %>"
               class="nav-menu-item"
               data-testid="nav-item-<%= item.toLowerCase() %>"
               data-item="<%= item %>"
               style="display:block;padding:9px 14px;border-radius:6px;color:var(--text);
                      font-size:14px;transition:all .2s;">
              <%= item %>
            </a>
          </li>
        <% }); %>
      </ul>
    </nav>
  </div>
</div>

