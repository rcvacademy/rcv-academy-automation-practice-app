<%# Contact Us Page %>
<div class="page-header">
  <h2><i class="fas fa-envelope" aria-hidden="true"></i> Contact Us</h2>
  <p>A complete contact form with multiple field types. All elements have rich locator-friendly attributes.</p>
</div>

<% if (typeof message !== 'undefined' && message) { %>
  <div id="contact-success" class="alert alert-success" role="alert" data-testid="contact-success">
    <i class="fas fa-check-circle" aria-hidden="true"></i>
    <span><%= message.text %></span>
  </div>
<% } %>

<div class="d-flex gap-3 flex-wrap">
  <!-- Contact form -->
  <div style="flex:2;min-width:320px;">
    <div class="card">
      <h3 class="card-title">Send Us a Message</h3>
      <form id="contact-form" name="contactForm" class="contact-form"
            method="POST" action="/contact-us"
            data-testid="contact-form" aria-label="Contact us form" novalidate>

        <div class="d-flex gap-2" style="flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:140px;">
            <label class="form-label" for="contact-firstname">First Name *</label>
            <input type="text" id="contact-firstname" name="firstName"
                   class="form-control" placeholder="First name"
                   data-testid="contact-firstname" required aria-required="true" />
          </div>
          <div class="form-group" style="flex:1;min-width:140px;">
            <label class="form-label" for="contact-lastname">Last Name *</label>
            <input type="text" id="contact-lastname" name="lastName"
                   class="form-control" placeholder="Last name"
                   data-testid="contact-lastname" required aria-required="true" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-email">Email Address *</label>
          <input type="email" id="contact-email" name="email"
                 class="form-control" placeholder="you@example.com"
                 data-testid="contact-email" required aria-required="true" />
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-phone">Phone Number</label>
          <input type="tel" id="contact-phone" name="phone"
                 class="form-control" placeholder="+1 (555) 000-0000"
                 data-testid="contact-phone" />
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-subject">Subject *</label>
          <select id="contact-subject" name="subject" class="form-control"
                  data-testid="contact-subject" required aria-required="true">
            <option value="">-- Select a subject --</option>
            <option value="general">General Inquiry</option>
            <option value="support">Technical Support</option>
            <option value="billing">Billing Question</option>
            <option value="feedback">Feedback</option>
            <option value="partnership">Partnership</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-message">Message *</label>
          <textarea id="contact-message" name="message" class="form-control"
                    placeholder="How can we help you?" rows="5"
                    data-testid="contact-message" required aria-required="true"
                    minlength="10"></textarea>
          <p class="form-text" id="contact-char-count" data-testid="contact-char-count">0 characters</p>
        </div>

        <!-- Rating (star) -->
        <div class="form-group">
          <label class="form-label">How did you hear about us?</label>
          <div class="radio-group" id="referral-group" role="radiogroup" aria-label="Referral source">
            <label><input type="radio" name="referral" value="search"    class="referral-radio" data-testid="referral-search"   id="referral-search"    /> Search Engine</label>
            <label><input type="radio" name="referral" value="social"    class="referral-radio" data-testid="referral-social"   id="referral-social"    /> Social Media</label>
            <label><input type="radio" name="referral" value="friend"    class="referral-radio" data-testid="referral-friend"   id="referral-friend"    /> Friend / Colleague</label>
            <label><input type="radio" name="referral" value="other"     class="referral-radio" data-testid="referral-other"    id="referral-other"     /> Other</label>
          </div>
        </div>

        <div class="form-group d-flex align-center gap-2">
          <input type="checkbox" id="contact-newsletter" name="newsletter"
                 value="yes" data-testid="contact-newsletter" checked />
          <label for="contact-newsletter" style="cursor:pointer;font-size:14px;">
            Subscribe to newsletter
          </label>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" id="contact-submit-btn" class="btn btn-primary"
                  data-testid="contact-submit" aria-label="Send message">
            <i class="fas fa-paper-plane" aria-hidden="true"></i> Send Message
          </button>
          <button type="reset" id="contact-reset-btn" class="btn btn-outline"
                  data-testid="contact-reset" aria-label="Reset form">
            <i class="fas fa-undo" aria-hidden="true"></i> Reset
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Contact details sidebar -->
  <div style="flex:1;min-width:220px;">
    <div class="card" id="contact-info-card" data-testid="contact-info-card">
      <h3 class="card-title"><i class="fas fa-map-marker-alt" aria-hidden="true"></i> Contact Info</h3>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:12px;font-size:13.5px;overflow:hidden;">
        <li id="contact-email-info" data-testid="contact-email-info" style="display:flex;align-items:flex-start;gap:8px;word-break:break-all;">
          <i class="fas fa-envelope" style="color:var(--primary);min-width:20px;margin-top:3px;" aria-hidden="true"></i>
          <a href="mailto:admin@rcvacademy.com">admin@rcvacademy.com</a>
        </li>
        <li id="contact-email-info-2" data-testid="contact-email-info-2" style="display:flex;align-items:flex-start;gap:8px;word-break:break-all;">
          <i class="fas fa-envelope" style="color:var(--primary);min-width:20px;margin-top:3px;" aria-hidden="true"></i>
          <a href="mailto:admin@softwaretestingmentor.com">admin@softwaretestingmentor.com</a>
        </li>
        <li id="contact-address-info" data-testid="contact-address-info" style="display:flex;align-items:flex-start;gap:8px;">
          <i class="fas fa-map-marker-alt" style="color:var(--primary);min-width:20px;margin-top:3px;" aria-hidden="true"></i>
          <span>Melbourne, 3000, VIC, Australia</span>
        </li>
        <li id="contact-hours-info" data-testid="contact-hours-info" style="display:flex;align-items:flex-start;gap:8px;">
          <i class="fas fa-clock" style="color:var(--primary);min-width:20px;margin-top:3px;" aria-hidden="true"></i>
          <span>Mon–Fri: 9 AM – 6 PM AEST</span>
        </li>
      </ul>
    </div>
  </div>
</div>

<script>
  // Character counter
  document.getElementById('contact-message').addEventListener('input', function () {
    document.getElementById('contact-char-count').textContent = this.value.length + ' characters';
  });
</script>
