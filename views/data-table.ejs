<%# Data Table with Sample Data %>
<div class="page-header">
  <h2><i class="fas fa-database"></i> Data Table with Sample Data</h2>
  <p>A rich static data table. Practice locating cells by row index, column header text, and cell value. Also filterable and searchable.</p>
</div>

<div class="card">
  <div class="d-flex align-center gap-2 mb-3" style="flex-wrap:wrap;">
    <input type="text" id="dt-search" class="form-control" placeholder="Filter rows…"
           aria-label="Filter data table" data-testid="dt-search" style="max-width:260px;" />
    <select id="dt-dept-filter" class="form-control" style="width:auto;"
            aria-label="Filter by department" data-testid="dt-dept-filter">
      <option value="">All Departments</option>
      <option value="Engineering">Engineering</option>
      <option value="Marketing">Marketing</option>
      <option value="Finance">Finance</option>
      <option value="HR">HR</option>
      <option value="Sales">Sales</option>
      <option value="Design">Design</option>
    </select>
    <button id="dt-export-btn" class="btn btn-outline btn-sm"
            data-testid="dt-export-btn" aria-label="Export table to CSV">
      <i class="fas fa-download"></i> Export CSV
    </button>
    <span id="dt-row-count" class="badge badge-primary" data-testid="dt-row-count"></span>
  </div>

  <div class="table-wrapper">
    <table class="data-table" id="employee-data-table"
           aria-label="Employee data table" data-testid="employee-data-table">
      <thead id="dt-head">
        <tr>
          <th data-col="id">        ID</th>
          <th data-col="name">      Name</th>
          <th data-col="email">     Email</th>
          <th data-col="dept">      Department</th>
          <th data-col="role">      Role</th>
          <th data-col="salary">    Salary</th>
          <th data-col="joined">    Joined</th>
          <th data-col="status">    Status</th>
        </tr>
      </thead>
      <tbody id="dt-tbody">
        <!-- Rendered by JS -->
      </tbody>
    </table>
  </div>
</div>

