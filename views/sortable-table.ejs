<%# Sortable Data Tables %>
<div class="page-header">
  <h2><i class="fas fa-sort"></i> Sortable Data Tables</h2>
  <p>Click any column header to sort the table. Practice verifying sort order and locating sort indicators.</p>
</div>

<div class="card">
  <div class="card-title">Products — Click Headers to Sort</div>
  <div class="d-flex align-center gap-2 mb-3" style="flex-wrap:wrap;">
    <input type="text" id="sort-search" class="form-control" placeholder="Filter products…"
           aria-label="Filter sortable table" data-testid="sort-search" style="max-width:260px;" />
    <span id="sort-indicator" class="badge badge-primary" data-testid="sort-indicator">
      Sorted by: ID ↑
    </span>
    <button id="reset-sort-btn" class="btn btn-outline btn-sm"
            data-testid="reset-sort-btn" aria-label="Reset table sort">Reset Sort</button>
  </div>

  <div class="table-wrapper">
    <table class="data-table" id="sortable-products-table"
           aria-label="Sortable products table" data-testid="sortable-products-table">
      <thead id="sort-head">
        <tr>
          <th data-sort-col="id"       data-sort-dir="asc"  class="sortable sort-asc"
              id="sort-col-id"         data-testid="sort-col-id"
              aria-sort="ascending">
            ID <i class="fas fa-sort-up sort-icon"></i>
          </th>
          <th data-sort-col="name"     data-sort-dir="none" class="sortable"
              id="sort-col-name"       data-testid="sort-col-name"
              aria-sort="none">
            Product Name <i class="fas fa-sort sort-icon"></i>
          </th>
          <th data-sort-col="category" data-sort-dir="none" class="sortable"
              id="sort-col-category"   data-testid="sort-col-category"
              aria-sort="none">
            Category <i class="fas fa-sort sort-icon"></i>
          </th>
          <th data-sort-col="price"    data-sort-dir="none" class="sortable"
              id="sort-col-price"      data-testid="sort-col-price"
              aria-sort="none">
            Price <i class="fas fa-sort sort-icon"></i>
          </th>
          <th data-sort-col="stock"    data-sort-dir="none" class="sortable"
              id="sort-col-stock"      data-testid="sort-col-stock"
              aria-sort="none">
            Stock <i class="fas fa-sort sort-icon"></i>
          </th>
          <th data-sort-col="rating"   data-sort-dir="none" class="sortable"
              id="sort-col-rating"     data-testid="sort-col-rating"
              aria-sort="none">
            Rating <i class="fas fa-sort sort-icon"></i>
          </th>
          <th data-sort-col="instock"  data-sort-dir="none" class="sortable"
              id="sort-col-instock"    data-testid="sort-col-instock"
              aria-sort="none">
            In Stock <i class="fas fa-sort sort-icon"></i>
          </th>
        </tr>
      </thead>
      <tbody id="sort-tbody"></tbody>
    </table>
  </div>
</div>

