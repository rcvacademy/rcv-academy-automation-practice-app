<%# Mouse Hover Page %>
<div class="page-header">
  <h2><i class="fas fa-hand-pointer" aria-hidden="true"></i> Mouse Hover</h2>
  <p>Practice triggering hover states, revealing hidden elements, and verifying hover-activated content with automation tools.</p>
</div>

<!-- Colour-change boxes -->
<div class="card">
  <h3 class="card-title">Hover to Change Style</h3>
  <div class="d-flex gap-3 flex-wrap">
    <div id="hover-box-1" class="hover-box" data-testid="hover-box-1"
         aria-label="Hover box 1">
      Hover Me
      <div class="hover-reveal-text">Revealed on hover!</div>
    </div>
    <div id="hover-box-2" class="hover-box" data-testid="hover-box-2"
         aria-label="Hover box 2"
         style="background:var(--primary-light);color:var(--primary);">
      Also Hover Me
      <div class="hover-reveal-text">I was hidden!</div>
    </div>
    <div id="hover-box-3" class="hover-box" data-testid="hover-box-3"
         aria-label="Hover box 3"
         style="background:#f0fdf4;color:var(--success);border:1px solid var(--success);">
      And Me
      <div class="hover-reveal-text">Found it! 🎉</div>
    </div>
  </div>
</div>

<!-- Dropdown revealed on hover -->
<div class="card">
  <h3 class="card-title">Hover Dropdown Menu</h3>
  <p class="text-muted mb-3" style="font-size:13px;">Hover over the button to reveal the dropdown. Options disappear when you move away.</p>
  <div id="hover-dropdown-wrapper" class="hover-dropdown-wrapper"
       style="position:relative;display:inline-block;"
       data-testid="hover-dropdown-wrapper">
    <button id="hover-dropdown-trigger" class="btn btn-primary"
            data-testid="hover-dropdown-trigger" aria-haspopup="true"
            aria-expanded="false" aria-label="Hover dropdown trigger"
            style="position:relative;z-index:2;">
      Account <i class="fas fa-chevron-down" aria-hidden="true"></i>
    </button>
    <ul id="hover-dropdown-menu"
        style="display:none;position:absolute;top:100%;left:0;
               background:var(--card-bg);border:1px solid var(--border);
               border-radius:var(--radius);box-shadow:var(--shadow-md);
               min-width:180px;z-index:1000;list-style:none;padding:4px 0;"
        data-testid="hover-dropdown-menu" role="menu">
      <li><a href="#" id="hdd-profile" class="hover-dd-item" role="menuitem"
             data-testid="hdd-profile"
             style="display:block;padding:9px 16px;font-size:13.5px;color:var(--text);">
        <i class="fas fa-user" aria-hidden="true"></i> Profile</a></li>
      <li><a href="#" id="hdd-settings" class="hover-dd-item" role="menuitem"
             data-testid="hdd-settings"
             style="display:block;padding:9px 16px;font-size:13.5px;color:var(--text);">
        <i class="fas fa-cog" aria-hidden="true"></i> Settings</a></li>
      <li><a href="#" id="hdd-billing" class="hover-dd-item" role="menuitem"
             data-testid="hdd-billing"
             style="display:block;padding:9px 16px;font-size:13.5px;color:var(--text);">
        <i class="fas fa-credit-card" aria-hidden="true"></i> Billing</a></li>
      <li style="border-top:1px solid var(--border);">
        <a href="#" id="hdd-logout" class="hover-dd-item" role="menuitem"
           data-testid="hdd-logout"
           style="display:block;padding:9px 16px;font-size:13.5px;color:var(--danger);">
          <i class="fas fa-sign-out-alt" aria-hidden="true"></i> Logout</a></li>
    </ul>
  </div>
  <p id="hover-dd-result" class="mt-3 text-muted" data-testid="hover-dd-result" style="font-size:13px;"></p>
</div>

<!-- Image hover overlay -->
<div class="card">
  <h3 class="card-title">Image with Hover Overlay</h3>
  <div class="d-flex gap-3 flex-wrap">
    <% ['Product A','Product B','Product C'].forEach(function(name, i){ %>
      <div id="img-hover-<%= i+1 %>"
           style="position:relative;width:160px;height:120px;border-radius:var(--radius);
                  background:var(--primary-light);overflow:hidden;cursor:pointer;"
           data-testid="img-hover-<%= i+1 %>" aria-label="<%= name %> hover card">
        <div style="display:flex;align-items:center;justify-content:center;
                    height:100%;font-size:14px;font-weight:600;color:var(--primary);">
          <%= name %>
        </div>
        <!-- overlay -->
        <div class="img-hover-overlay"
             style="position:absolute;inset:0;background:rgba(79,70,229,.85);
                    display:flex;flex-direction:column;align-items:center;
                    justify-content:center;gap:6px;opacity:0;transition:.3s;color:#fff;
                    font-size:13px;"
             data-testid="overlay-<%= i+1 %>">
          <i class="fas fa-eye" style="font-size:20px;" aria-hidden="true"></i>
          <span>View Details</span>
        </div>
      </div>
    <% }); %>
  </div>
</div>



<script>
  // Hover dropdown
  const wrapper = document.getElementById('hover-dropdown-wrapper');
  const menu    = document.getElementById('hover-dropdown-menu');
  const trigger = document.getElementById('hover-dropdown-trigger');

  wrapper.addEventListener('mouseenter', function () {
    menu.style.display = 'block';
    trigger.setAttribute('aria-expanded', 'true');
  });
  wrapper.addEventListener('mouseleave', function () {
    menu.style.display = 'none';
    trigger.setAttribute('aria-expanded', 'false');
  });

  document.querySelectorAll('.hover-dd-item').forEach(function (item) {
    item.addEventListener('click', function (e) {
      e.preventDefault();
      document.getElementById('hover-dd-result').textContent = '✅ Clicked: ' + item.textContent.trim();
    });
  });

  // Image hover overlay
  document.querySelectorAll('[id^="img-hover-"]').forEach(function (box) {
    const overlay = box.querySelector('.img-hover-overlay');
    box.addEventListener('mouseenter', function () { overlay.style.opacity = '1'; });
    box.addEventListener('mouseleave', function () { overlay.style.opacity = '0'; });
  });
</script>
