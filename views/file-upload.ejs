<%# File Upload Page %>
<div class="page-header">
  <h2><i class="fas fa-upload" aria-hidden="true"></i> File Upload</h2>
  <p>Practice locating file input elements, upload result messages, and multiple file uploads.</p>
</div>

<% var allowed = '.jpg, .jpeg, .png, .gif, .bmp, .webp, .pdf, .doc, .docx, .xls, .xlsx, .ppt, .pptx, .txt, .csv'; %>

<% if (typeof uploadError !== 'undefined' && uploadError) { %>
  <div id="upload-error" class="alert alert-danger" role="alert" data-testid="upload-error">
    <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
    <%= uploadError %>
  </div>
<% } %>

<% if (typeof uploadedFile !== 'undefined' && uploadedFile) { %>
  <div id="upload-success" class="alert alert-success" role="alert" data-testid="upload-success">
    <i class="fas fa-check-circle" aria-hidden="true"></i>
    File "<strong><%= uploadedFile %></strong>" uploaded successfully!
  </div>
<% } %>

<% if (typeof uploadedFiles !== 'undefined' && uploadedFiles && uploadedFiles.length) { %>
  <div id="multi-upload-success" class="alert alert-success" role="alert" data-testid="multi-upload-success">
    <i class="fas fa-check-circle" aria-hidden="true"></i>
    <strong><%= uploadedFiles.length %></strong> file(s) uploaded:
    <ul style="margin:6px 0 0 18px;font-size:13px;">
      <% uploadedFiles.forEach(function(f) { %>
        <li><%= f %></li>
      <% }); %>
    </ul>
  </div>
<% } %>

<!-- Standard file input -->
<div class="card" style="max-width:560px;">
  <h3 class="card-title">Standard File Upload</h3>
  <form id="upload-form" method="POST" action="/file-upload"
        enctype="multipart/form-data" data-testid="upload-form">

    <div class="form-group">
      <label class="form-label" for="uploadFile">Choose a file</label>
      <input type="file" id="uploadFile" name="uploadFile"
             class="form-control" accept="<%= allowed %>"
             aria-label="Choose file to upload"
             data-testid="file-input" />
      <p class="form-text">Allowed: images and documents only (max 100 KB).</p>
    </div>

    <button type="submit" id="upload-btn" class="btn btn-primary"
            data-testid="upload-btn" aria-label="Upload file">
      <i class="fas fa-upload" aria-hidden="true"></i> Upload
    </button>
  </form>
</div>

<!-- Multiple files -->
<div class="card" style="max-width:560px;">
  <h3 class="card-title">Multiple File Upload</h3>
  <form id="multi-upload-form" method="POST" action="/file-upload-multi"
        enctype="multipart/form-data" data-testid="multi-upload-form">
    <div class="form-group">
      <label class="form-label" for="multi-file-input">Select multiple files</label>
      <input type="file" id="multi-file-input" name="files"
             class="form-control" multiple accept="<%= allowed %>"
             aria-label="Select multiple files"
             data-testid="multi-file-input" />
      <p class="form-text">Allowed: images and documents only (max 100 KB each, up to 10 files).</p>
    </div>
    <div id="multi-file-preview" data-testid="multi-file-preview" style="font-size:13px;"></div>
    <div style="display:flex;gap:8px;margin-top:8px;">
      <button type="submit" id="multi-upload-btn" class="btn btn-primary"
              data-testid="multi-upload-btn" aria-label="Upload multiple files">
        <i class="fas fa-upload" aria-hidden="true"></i> Upload All
      </button>
      <button type="button" id="clear-files-btn" class="btn btn-outline btn-sm"
              data-testid="clear-files-btn">Clear</button>
    </div>
  </form>
</div>


