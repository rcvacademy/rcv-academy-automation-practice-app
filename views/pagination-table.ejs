<%# Pagination Table – navigate pages, locate rows by current page %>
<div class="page-header">
  <h2><i class="fas fa-list-ol"></i> Dynamic Pagination Table</h2>
  <p>A large dataset split across multiple pages. Practice locating page buttons, row counts, and specific cells.</p>
</div>

<div class="card">
  <div class="d-flex align-center gap-2 mb-3" style="flex-wrap:wrap;">
    <label for="page-size-select" class="form-label" style="margin:0;">Rows per page:</label>
    <select id="page-size-select" class="form-control" style="width:auto;" data-testid="page-size">
      <option value="5" selected>5</option>
      <option value="10">10</option>
      <option value="20">20</option>
    </select>
    <input type="text" id="pag-search" class="form-control" placeholder="Search…"
           data-testid="pag-search" aria-label="Search pagination table" style="max-width:220px;" />
    <span id="pag-info" class="badge badge-primary" data-testid="pag-info">Showing 1–5 of 50</span>
  </div>

  <div class="table-wrapper">
    <table class="data-table" id="pagination-table" aria-label="Paginated product table" data-testid="pagination-table">
      <thead>
        <tr>
          <th data-col="id">ID</th>
          <th data-col="product">Product</th>
          <th data-col="category">Category</th>
          <th data-col="price">Price</th>
          <th data-col="stock">Stock</th>
          <th data-col="rating">Rating</th>
        </tr>
      </thead>
      <tbody id="pag-table-body"></tbody>
    </table>
  </div>

  <!-- Pagination controls -->
  <div class="pagination" id="pagination-controls" role="navigation" aria-label="Table pagination">
    <button id="pag-prev" class="page-btn" data-testid="pag-prev" aria-label="Previous page">&#8592; Prev</button>
    <span id="pag-page-numbers" class="d-flex gap-2"></span>
    <button id="pag-next" class="page-btn" data-testid="pag-next" aria-label="Next page">Next &#8594;</button>
  </div>
</div>

