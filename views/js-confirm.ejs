<%# JS Confirm Page %>
<div class="page-header">
  <h2><i class="fas fa-question-circle"></i> JS Confirm</h2>
  <p>Trigger native <code>confirm()</code> dialogs that return <code>true</code> (OK) or <code>false</code> (Cancel). Practice accepting and dismissing confirms.</p>
</div>

<div class="alert alert-info" role="note">
  <i class="fas fa-info-circle"></i>
  A browser confirm dialog will appear. Press <strong>OK</strong> to accept or <strong>Cancel</strong> to dismiss.
</div>

<!-- Basic confirm -->
<div class="card">
  <div class="card-title">Delete Confirmation</div>
  <p class="text-muted mb-3" style="font-size:13px;">A common pattern: ask the user whether they really want to delete an item.</p>
  <button id="trigger-confirm-btn" class="btn btn-danger"
          data-testid="trigger-confirm-btn" aria-label="Trigger delete confirm dialog">
    <i class="fas fa-trash"></i> Delete Item
  </button>
  <div id="confirm-result" class="mt-3" data-testid="confirm-result" style="font-size:14px;"></div>
</div>

<!-- Confirm before navigation -->
<div class="card">
  <div class="card-title">Confirm Before Navigation</div>
  <p class="text-muted mb-3" style="font-size:13px;">Confirm whether you really want to go to an external URL.</p>
  <button id="trigger-nav-confirm" class="btn btn-primary"
          data-testid="trigger-nav-confirm" aria-label="Navigate with confirm">
    <i class="fas fa-external-link-alt"></i> Go to External Site?
  </button>
  <div id="nav-confirm-result" class="mt-3 text-muted" data-testid="nav-confirm-result" style="font-size:13px;"></div>
</div>

<!-- Multiple confirms in sequence -->
<div class="card">
  <div class="card-title">Sequential Confirms</div>
  <p class="text-muted mb-3" style="font-size:13px;">Two confirm dialogs in a row — both must be accepted to see the success message.</p>
  <button id="trigger-multi-confirm" class="btn btn-warning"
          data-testid="trigger-multi-confirm" aria-label="Trigger sequential confirms">
    <i class="fas fa-layer-group"></i> Confirm Twice
  </button>
  <div id="multi-confirm-result" class="mt-3 text-muted" data-testid="multi-confirm-result" style="font-size:13px;"></div>
</div>



<script>
  document.getElementById('trigger-confirm-btn').addEventListener('click', function () {
    const result = confirm('Are you sure you want to delete this item? This cannot be undone.');
    const el = document.getElementById('confirm-result');
    if (result) {
      el.innerHTML = '<span style="color:var(--success);">✅ Item deleted! (OK was pressed)</span>';
    } else {
      el.innerHTML = '<span style="color:var(--danger);">❌ Deletion cancelled. (Cancel was pressed)</span>';
    }
  });

  document.getElementById('trigger-nav-confirm').addEventListener('click', function () {
    const ok = confirm('You are about to leave this page. Continue?');
    document.getElementById('nav-confirm-result').textContent = ok
      ? '✅ Navigation confirmed — you chose to continue.'
      : '❌ Navigation cancelled.';
  });

  document.getElementById('trigger-multi-confirm').addEventListener('click', function () {
    const first  = confirm('Step 1 of 2: Are you sure?');
    if (!first) { document.getElementById('multi-confirm-result').textContent = '❌ Aborted at step 1.'; return; }
    const second = confirm('Step 2 of 2: Are you really sure?');
    document.getElementById('multi-confirm-result').textContent = second
      ? '✅ Both confirms accepted — action completed!'
      : '❌ Aborted at step 2.';
  });
</script>
