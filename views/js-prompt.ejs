<%# JS Prompt Page %>
<div class="page-header">
  <h2><i class="fas fa-comment-dots" aria-hidden="true"></i> JS Prompt</h2>
  <p>Trigger <code>window.prompt()</code> dialogs that accept user text input. Practice reading the returned value and handling dismissal.</p>
</div>

<div class="alert alert-info" role="note">
  <i class="fas fa-info-circle" aria-hidden="true"></i>
  A browser text-entry prompt will appear. Type a value and click <strong>OK</strong>, or <strong>Cancel</strong> to return null.
</div>

<!-- Basic prompt -->
<div class="card">
  <h3 class="card-title">Simple Name Prompt</h3>
  <p class="text-muted mb-3" style="font-size:13px;">Enter your name in the browser prompt. The result is displayed below.</p>
  <button id="trigger-prompt-btn" class="btn btn-primary"
          data-testid="trigger-prompt-btn" aria-label="Trigger name prompt">
    <i class="fas fa-user" aria-hidden="true"></i> Enter Your Name
  </button>
  <p id="prompt-result" class="mt-3" data-testid="prompt-result" style="font-size:14px;"></p>
</div>

<!-- Prompt with default value -->
<div class="card">
  <h3 class="card-title">Prompt with Default Value</h3>
  <p class="text-muted mb-3" style="font-size:13px;">A prompt pre-filled with a default value. You can modify it or accept it as-is.</p>
  <button id="trigger-default-prompt" class="btn btn-primary"
          data-testid="trigger-default-prompt" aria-label="Trigger prompt with default value">
    <i class="fas fa-edit" aria-hidden="true"></i> Edit Your City
  </button>
  <p id="default-prompt-result" class="mt-3 text-muted" data-testid="default-prompt-result" style="font-size:14px;"></p>
</div>

<!-- Prompt in form flow -->
<div class="card" style="max-width:480px;">
  <h3 class="card-title">Prompt as Part of a Form</h3>
  <p class="text-muted mb-2" style="font-size:13px;">Clicking Submit triggers a prompt asking for a coupon code before the form proceeds.</p>
  <form id="prompt-form" data-testid="prompt-form" aria-label="Order form with coupon prompt">
    <div class="form-group">
      <label class="form-label" for="order-product">Product</label>
      <select id="order-product" name="product" class="form-control" data-testid="order-product">
        <option value="basic">Basic Plan – $9/mo</option>
        <option value="pro">Pro Plan – $19/mo</option>
        <option value="enterprise">Enterprise – $49/mo</option>
      </select>
    </div>
    <button type="submit" id="order-submit-btn" class="btn btn-primary"
            data-testid="order-submit-btn" aria-label="Submit order">
      <i class="fas fa-shopping-cart" aria-hidden="true"></i> Place Order
    </button>
  </form>
  <p id="order-result" class="mt-3 text-muted" data-testid="order-result" style="font-size:14px;"></p>
</div>



<script>
  document.getElementById('trigger-prompt-btn').addEventListener('click', function () {
    var name = prompt('What is your name?');
    var el = document.getElementById('prompt-result');
    el.textContent = '';
    if (name === null)            { el.style.color = 'var(--danger)';  el.textContent = '❌ Prompt was cancelled.'; }
    else if (name.trim() === '')  { el.style.color = 'var(--warning)'; el.textContent = '⚠️ No name entered.'; }
    else                          { el.style.color = 'var(--success)'; el.textContent = '✅ Hello, ' + name + '!'; }
  });

  document.getElementById('trigger-default-prompt').addEventListener('click', function () {
    var city = prompt('Enter your city:', 'New York');
    document.getElementById('default-prompt-result').textContent = city !== null
      ? '📍 City entered: ' + (city || '(empty)')
      : '❌ Cancelled.';
  });

  document.getElementById('prompt-form').addEventListener('submit', function (e) {
    e.preventDefault();
    var code = prompt('Enter coupon code (or leave blank for no discount):', '');
    var product = document.getElementById('order-product').value;
    var el = document.getElementById('order-result');
    if (code === null) {
      el.textContent = '❌ Order cancelled.';
    } else if (code.toUpperCase() === 'SAVE20') {
      el.textContent = '✅ Coupon applied! 20% off ' + product + ' placed.';
    } else {
      el.textContent = '✅ Order for ' + product + ' placed' + (code ? ' (invalid coupon)' : '') + '.';
    }
  });
</script>
