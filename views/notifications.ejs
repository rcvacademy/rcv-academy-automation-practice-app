<%# Notification Messages Page %>
<div class="page-header">
  <h2><i class="fas fa-bell"></i> Notification Messages</h2>
  <p>Trigger and locate toast notifications, inline alerts, banners, and badges. Practice waiting for elements to appear/disappear.</p>
</div>

<!-- Button panel to trigger toasts -->
<div class="card">
  <div class="card-title">Trigger Notifications</div>
  <div class="d-flex gap-2 flex-wrap">
    <button id="btn-success-toast" class="btn btn-success"
            data-testid="btn-success-toast" aria-label="Show success notification">
      <i class="fas fa-check-circle"></i> Success
    </button>
    <button id="btn-error-toast" class="btn btn-danger"
            data-testid="btn-error-toast" aria-label="Show error notification">
      <i class="fas fa-times-circle"></i> Error
    </button>
    <button id="btn-warning-toast" class="btn btn-warning"
            data-testid="btn-warning-toast" aria-label="Show warning notification">
      <i class="fas fa-exclamation-triangle"></i> Warning
    </button>
    <button id="btn-info-toast" class="btn btn-outline"
            data-testid="btn-info-toast" aria-label="Show info notification"
            style="color:var(--accent);border-color:var(--accent);">
      <i class="fas fa-info-circle"></i> Info
    </button>
    <button id="btn-auto-dismiss" class="btn btn-outline"
            data-testid="btn-auto-dismiss" aria-label="Show auto-dismiss notification">
      <i class="fas fa-clock"></i> Auto-Dismiss (3 s)
    </button>
  </div>
</div>

<!-- Inline alert styles -->
<div class="card">
  <div class="card-title">Inline Alert Variants</div>
  <div id="alert-success-inline" class="alert alert-success" role="alert"
       data-testid="alert-success-inline" data-type="success">
    <i class="fas fa-check-circle"></i>
    <strong>Success!</strong> Your changes have been saved.
  </div>
  <div id="alert-error-inline" class="alert alert-error" role="alert"
       data-testid="alert-error-inline" data-type="error">
    <i class="fas fa-exclamation-circle"></i>
    <strong>Error!</strong> Something went wrong. Please try again.
  </div>
  <div id="alert-warning-inline" class="alert alert-warning" role="alert"
       data-testid="alert-warning-inline" data-type="warning">
    <i class="fas fa-exclamation-triangle"></i>
    <strong>Warning!</strong> Your session will expire in 5 minutes.
  </div>
  <div id="alert-info-inline" class="alert alert-info" role="alert"
       data-testid="alert-info-inline" data-type="info">
    <i class="fas fa-info-circle"></i>
    A new version is available. <a href="#" id="update-link" data-testid="update-link">Update now</a>
  </div>
</div>

<!-- Dismissible alert -->
<div class="card" style="max-width:480px;">
  <div class="card-title">Dismissible Alert</div>
  <div id="dismissible-alert" class="alert alert-info"
       data-testid="dismissible-alert" style="display:flex;justify-content:space-between;align-items:center;">
    <span><i class="fas fa-info-circle"></i> Click × to dismiss this alert.</span>
    <button id="dismiss-alert-btn" style="background:none;border:none;cursor:pointer;font-size:18px;line-height:1;"
            data-testid="dismiss-alert-btn" aria-label="Dismiss alert">&times;</button>
  </div>
  <button id="show-alert-btn" class="btn btn-outline btn-sm" style="display:none;"
          data-testid="show-alert-btn" aria-label="Show alert again">Show alert again</button>
</div>

<!-- Badge / counter -->
<div class="card">
  <div class="card-title">Badges &amp; Counters</div>
  <div class="d-flex gap-3 align-center flex-wrap">
    <button id="new-message-btn" class="btn btn-primary" style="position:relative;"
            data-testid="new-message-btn" aria-label="Messages inbox">
      <i class="fas fa-envelope"></i> Messages
      <span id="message-badge" class="badge"
            style="position:absolute;top:-6px;right:-8px;background:var(--danger);
                   color:#fff;min-width:20px;height:20px;border-radius:50%;
                   display:flex;align-items:center;justify-content:center;font-size:11px;"
            data-testid="message-badge">3</span>
    </button>
    <button id="clear-badge-btn" class="btn btn-outline btn-sm"
            data-testid="clear-badge-btn" aria-label="Mark messages as read">Mark as read</button>
    <button id="add-badge-btn" class="btn btn-outline btn-sm"
            data-testid="add-badge-btn" aria-label="Add new message">+ New message</button>
  </div>
</div>

<!-- Toast container (rendered by main.js) -->
<div id="toast-container" aria-live="polite" aria-label="Notification area"></div>


